# Copy this file to `keystore.properties` (which is git-ignored) and fill in real values.
# Generate an upload keystore with:
#   keytool -genkey -v -keystore leanster-upload.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile path is relative to the project root.
storeFile=leanster-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
